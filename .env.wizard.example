# MEGA-STACK v5.2 Installation Wizard — Environment Variables (EXAMPLE)
# Bu dosyayı .env.wizard olarak kopyalayıp değerlerinizi girin.
WIZARD_VERSION=2.5.0
WIZARD_HOST=0.0.0.0
WIZARD_PORT=9999
DEBUG=False
LOG_LEVEL=INFO
MEGA_STACK_DIR=/opt/mega-stack

# Domain — Kurulum sırasında otomatik ayarlanır.
# CORS ve sertifika üretimi bu değere bağlıdır.
# WIZARD_DOMAIN=

# ReadOnly Proxy Token — Boş bırakılırsa her başlatmada otomatik üretilir.
# Prodüksiyonda sabit bir değer atayın: openssl rand -hex 32
# WIZARD_READONLY_TOKEN=
