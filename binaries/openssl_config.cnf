# ══════════════════════════════════════════════════════════════════════════
# MEGA-STACK v2.5 — OpenSSL Configuration
# Self-signed sertifika üretimi için izole konfigürasyon.
# Kullanım: openssl req -config openssl_config.cnf -new -x509 ...
# ══════════════════════════════════════════════════════════════════════════

[req]
default_bits       = 4096
default_md         = sha256
prompt             = no
encrypt_key        = no
distinguished_name = dn
x509_extensions    = v3_ca
string_mask        = utf8only

[dn]
C  = TR
ST = Istanbul
L  = Istanbul
O  = MEGA-STACK
OU = Infrastructure
CN = {{ domain }}

[v3_ca]
subjectKeyIdentifier   = hash
authorityKeyIdentifier = keyid:always,issuer
basicConstraints       = critical, CA:true
keyUsage               = critical, digitalSignature, cRLSign, keyCertSign

[v3_req]
basicConstraints     = CA:FALSE
keyUsage             = nonRepudiation, digitalSignature, keyEncipherment
subjectAltName       = @alt_names

[alt_names]
DNS.1 = {{ domain }}
DNS.2 = *.{{ domain }}
DNS.3 = localhost
IP.1  = 127.0.0.1
